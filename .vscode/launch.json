      "runtimeArgs": ["workspace", "@caroster/backend", "run", "develop"],
      "skipFiles": ["<node_internals>/**"],
      "outputCapture": "std"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Launch Program with Watch Admin",
      "runtimeExecutable": "yarn",
      "runtimeArgs": [
        "workspace",
        "@caroster/backend",
        "run",
        "develop",
        "--watch-admin"
      ],
      "skipFiles": ["<node_internals>/**"],
      "outputCapture": "std"
    }
  ]
